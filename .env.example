# Required: OpenRouter API key
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: customize the OpenRouter base URL (default: https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: Linear project management integration
# Get your API key at: https://linear.app/settings/api
# LINEAR_API_KEY=lin_api_...

# Optional: Dashboard authentication token
# If set, the dashboard will require this token via ?token=<TOKEN> query param
# or Authorization: Bearer <TOKEN> header
# DASHBOARD_TOKEN=your-secret-token

# Optional: Maximum concurrent LLM API calls (default: 5)
# SEMAPHORE_LIMIT=5
